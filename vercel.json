{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/download"
    },
    {
      "source": "/diaries/:diaryId",
      "destination": "/api/diaries?diaryId=:diaryId"
    }
  ]
}
